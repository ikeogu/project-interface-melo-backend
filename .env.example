# ── App ───────────────────────────────────────────────────────────────
APP_NAME="AI Contacts"
SECRET_KEY=generate-with-openssl-rand-hex-32
ENVIRONMENT=development
DEBUG=true
APP_BASE_URL=https://api.yourdomain.com
APP_DEEP_LINK_SCHEME=aicontacts

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ai_contacts
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_contacts
REDIS_URL=redis://localhost:6379/0

# ── Email (Resend — resend.com, free: 3,000/month) ────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_FROM_NAME=AI Contacts

# ── OAuth providers ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
MICROSOFT_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MICROSOFT_CLIENT_SECRET=your-client-secret
YAHOO_CLIENT_ID=dj0yJmk9xxxx
YAHOO_CLIENT_SECRET=xxxx

# ── LLM — Claude (primary) ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── LLM — Qwen via OpenRouter (fallback, ~20x cheaper) ───────────────
# Sign up at openrouter.ai — pay per token, no subscription
OPENROUTER_API_KEY=sk-or-...

# ── OpenAI — only used as Whisper API fallback if self-hosted is down ─
OPENAI_API_KEY=sk-...

# ── ElevenLabs — only used as TTS fallback if Kokoro is down ─────────
ELEVENLABS_API_KEY=your-key

# ── Tavus — video avatar (Phase 3 only) ──────────────────────────────
TAVUS_API_KEY=your-key

# ── Self-hosted services (started via docker-compose) ─────────────────
WHISPER_SERVICE_URL=http://localhost:8001    # faster-whisper container
KOKORO_SERVICE_URL=http://localhost:8880    # kokoro TTS container
VOXTRAL_SERVICE_URL=                        # only set if you have a GPU
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ── Storage ───────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_REGION=us-east-1
S3_BUCKET_NAME=ai-contacts-media
S3_ENDPOINT_URL=   # leave blank for AWS; set for Cloudflare R2

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081
